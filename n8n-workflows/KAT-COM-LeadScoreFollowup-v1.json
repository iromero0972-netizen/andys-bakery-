        "sheetName": { "__rl": true, "mode": "list", "value": "Leads" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "score": "={{ $json.score }}",
            "status": "scored",
            "next_action": "={{ $json.classification === 'SQL' ? 'contact_24h' : $json.classification === 'MQL' ? 'follow_up_day_1' : 'none' }}",
