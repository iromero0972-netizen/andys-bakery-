        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-sonnet-4-20250514\", max_tokens: 800, system: \"Eres un experto en lead scoring B2B para una agencia de automatización con IA que atiende PYMEs latinas en Texas. Tu cliente ideal (ICP): PYME en Houston/Katy, 5-50 empleados, industria servicios/retail/restaurantes, dueño hispanohablante, procesos manuales que se beneficiarían de automatización. Evalúa cada lead y responde SOLO con JSON válido, sin markdown.\", messages: [{ role: \"user\", content: \"Evalúa este lead:\\n\\nNombre: \" + $json.name + \"\\nEmpresa: \" + $json.company + \"\\nEmail: \" + $json.email + \"\\nTeléfono: \" + $json.phone + \"\\nMensaje: \" + $json.message + \"\\nFuente: \" + $json.source + \"\\n\\nResponde SOLO con este JSON:\\n{\\\"score\\\": <0-100>, \\\"classification\\\": \\\"SQL|MQL|DISCARD\\\", \\\"icp_fit\\\": <0-30>, \\\"pain_identified\\\": <0-25>, \\\"authority\\\": <0-20>, \\\"engagement\\\": <0-15>, \\\"timing\\\": <0-10>, \\\"reasoning\\\": \\\"<1 línea>\\\", \\\"suggested_approach\\\": \\\"<1 línea>\\\"}\" }] }) }}",
        "options": {}
      },
      "id": "wf02-node-04",
      "name": "Claude API: Lead Scoring",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            { "id": "f-score", "name": "score", "value": "={{ JSON.parse($json.data.content[0].text).score }}", "type": "number" },
            { "id": "f-class", "name": "classification", "value": "={{ JSON.parse($json.data.content[0].text).classification }}", "type": "string" },
            { "id": "f-reason", "name": "reasoning", "value": "={{ JSON.parse($json.data.content[0].text).reasoning }}", "type": "string" },
            { "id": "f-approach", "name": "suggested_approach", "value": "={{ JSON.parse($json.data.content[0].text).suggested_approach }}", "type": "string" }
          ]
        },
        "options": { "includeBinary": false }
      },
      "id": "wf02-node-05",
      "name": "Parsear Score",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [1120, 300]
